// === PARAGRAPH HELPERS ===
const mkRuns = c => Array.isArray(c) ? c.map(x=>typeof x==='string'?R(x):x) : [R(c)];

function P(content, opts={}) {
  return new Paragraph({ ...opts, children: mkRuns(content), spacing:{before:60,after:60} });
}
function Pindent(content) {
  return new Paragraph({ indent:{left:720}, children: mkRuns(content), spacing:{before:60,after:60} });
}
function Pbold(text) {
  return new Paragraph({ children:[R(text,{bold:true})], spacing:{before:60,after:60} });
}
function Pitalic(text) {
  return new Paragraph({ children:[R(text,{italics:true,color:'666666'})], spacing:{before:0,after:80} });
}
function Pformula(content) {
  return new Paragraph({ indent:{left:720}, children: mkRuns(content).map(r=>({...r,_element:r._element})), spacing:{before:80,after:80} });
}
function bull(content, lvl=0) {
  return new Paragraph({ numbering:{reference:'bullets',level:lvl}, children:mkRuns(content), spacing:{before:40,after:40} });
}
function numbered(content, lvl=0) {
  return new Paragraph({ numbering:{reference:'numbers',level:lvl}, children:mkRuns(content), spacing:{before:40,after:40} });
}
function Pempty() { return new Paragraph({ children:[], spacing:{before:80,after:80} }); }
function PB()     { return new Paragraph({ children:[new PageBreak()] }); }

