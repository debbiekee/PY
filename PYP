// === TABLE HELPERS ===
const HDR='1F4E79', ALT='D9E8F4';
const BDR={style:BorderStyle.SINGLE,size:4,color:'2E75B6'};
const BALL={top:BDR,bottom:BDR,left:BDR,right:BDR};
const CMARG={top:80,bottom:80,left:130,right:130};

function TC(content, isHdr=false, w=0, isAlt=false) {
  const fill = isHdr?HDR : isAlt?ALT:'FFFFFF';
  const col  = isHdr?'FFFFFF':'000000';
  let paras;
  if (Array.isArray(content) && content.length && content[0] instanceof Paragraph) {
    paras = content;
  } else {
    const runs = mkRuns(content).map(r => {
      if (r instanceof TextRun) return r;
      return R(String(r),{bold:isHdr,color:col,size:20});
    });
    const boldRuns = runs.map(tr => {
      if (isHdr && tr.options) tr.options.bold = true;
      return tr;
    });
    paras = [new Paragraph({ children: mkRuns(content).map(x=>typeof x==='string'? R(x,{bold:isHdr,color:col,size:20}) : x), spacing:{before:40,after:40} })];
  }
  return new TableCell({
    borders:BALL,
    width: w?{size:w,type:WidthType.DXA}:undefined,
    shading:{fill,type:ShadingType.CLEAR},
    margins:CMARG,
    children:paras
  });
}

function TR(cells, widths, isHdr=false, isAlt=false) {
  return new TableRow({
    tableHeader:isHdr,
    children: cells.map((c,i)=>TC(c,isHdr,widths[i],isAlt))
  });
}

function TBL(rows, widths) {
  const total=widths.reduce((a,b)=>a+b,0);
  return new Table({
    width:{size:total,type:WidthType.DXA},
    columnWidths:widths,
    rows: rows.map((row,ri)=>TR(row,widths,ri===0,ri>0&&ri%2===0))
  });
}

// For cells needing multiple paragraphs
function TCm(paragraphs, isHdr=false, w=0, isAlt=false) {
  const fill = isHdr?HDR:isAlt?ALT:'FFFFFF';
  return new TableCell({ borders:BALL, width:w?{size:w,type:WidthType.DXA}:undefined, shading:{fill,type:ShadingType.CLEAR}, margins:CMARG, children:paragraphs });
}

function TBLm(rowFn, widths) {
  const total=widths.reduce((a,b)=>a+b,0);
  return new Table({ width:{size:total,type:WidthType.DXA}, columnWidths:widths, rows:rowFn(widths) });
}

